{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Flashback",
  "version": "0.4.25",
  "identifier": "com.us.flashback",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Flashback",
        "decorations": true,
        "titleBarStyle": "Overlay",
        "url": "https://flashback.eu.com",
        "width": 1200,
        "height": 800
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["rpm", "deb"],
    "icon": [
      "icons/flashback.png"
    ]
  }
}
